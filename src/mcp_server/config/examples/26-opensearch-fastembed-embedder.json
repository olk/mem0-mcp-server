{
  "config_id": "opensearch-fastembed-embedder",
  "memory_expiry": 3600,
  "logging_level": "INFO",
  "host": "0.0.0.0",
  "port": 8080,
  "transport": "sse",
  "vector_store": {
    "provider": "opensearch",
    "collection_name": "mem0",
    "embedding_model_dims": 384,
    "opensearch_host": "search-xxx.amazonaws.com",
    "opensearch_port": 443,
    "opensearch_user": "admin",
    "opensearch_password": "your-password",
    "opensearch_use_ssl": true
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-4o",
    "temperature": 0.2,
    "max_tokens": 2000
  },
  "embedder": {
    "provider": "fastembed",
    "model": "BAAI/bge-small-en-v1.5",
    "dimension": 384
  }
}
