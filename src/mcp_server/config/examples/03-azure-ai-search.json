{
  "config_id": "azure-ai-search",
  "memory_expiry": 3600,
  "logging_level": "INFO",
  "host": "0.0.0.0",
  "port": 8080,
  "transport": "sse",
  "vector_store": {
    "provider": "azure_ai_search",
    "collection_name": "mem0",
    "embedding_model_dims": 1536,
    "azure_ai_search_service_name": "your-service-name",
    "azure_ai_search_api_key": "your-azure-search-api-key"
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-4o",
    "temperature": 0.2,
    "max_tokens": 2000
  },
  "embedder": {
    "provider": "openai",
    "model": "text-embedding-3-small",
    "dimension": 1536
  }
}
