    "model": "grok-2-1212",
    "temperature": 0.2,
    "max_tokens": 2000,
    "xai_base_url": "https://api.x.ai/v1"
  },
  "embedder": {
    "provider": "openai",
    "model": "text-embedding-3-small",
    "dimension": 1536
  }
}
