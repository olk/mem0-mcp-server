{
  "config_id": "pinecone-xai",
  "memory_expiry": 3600,
  "logging_level": "INFO",
  "host": "0.0.0.0",
  "port": 8080,
  "transport": "sse",
  "vector_store": {
    "provider": "pinecone",
    "collection_name": "mem0",
