{
  "config_id": "weaviate-litellm",
  "memory_expiry": 3600,
  "logging_level": "INFO",
  "host": "0.0.0.0",
  "port": 8080,
  "transport": "sse",
  "vector_store": {
    "provider": "weaviate",
    "collection_name": "mem0",
    "embedding_model_dims": 1536,
    "weaviate_cluster_url": "https://xxx.weaviate.cloud",
    "weaviate_auth_client_secret": "your-weaviate-api-key"
  },
  "llm": {
    "provider": "litellm",
    "model": "gpt-4",
    "temperature": 0.2,
    "max_tokens": 2000,
    "litellm_base_url": "https://your-proxy.com"
  },
  "embedder": {
    "provider": "openai",
    "model": "text-embedding-3-small",
    "dimension": 1536
  }
}
