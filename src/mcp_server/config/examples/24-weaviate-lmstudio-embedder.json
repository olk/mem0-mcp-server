{
  "config_id": "weaviate-lmstudio-embedder",
  "memory_expiry": 3600,
  "logging_level": "INFO",
  "host": "0.0.0.0",
  "port": 8080,
  "transport": "sse",
  "vector_store": {
    "provider": "weaviate",
    "collection_name": "mem0",
    "embedding_model_dims": 1536,
    "weaviate_cluster_url": "https://xxx.weaviate.cloud",
    "weaviate_auth_client_secret": "your-weaviate-api-key"
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-4o",
    "temperature": 0.2,
    "max_tokens": 2000
  },
  "embedder": {
    "provider": "lmstudio",
    "model": "your-model-name",
    "dimension": 1536,
    "lmstudio_base_url": "http://localhost:1234/v1"
  }
}
