{
  "config_id": "faiss-lmstudio",
  "memory_expiry": 3600,
  "logging_level": "INFO",
  "host": "0.0.0.0",
  "port": 8080,
  "transport": "sse",
  "vector_store": {
    "provider": "faiss",
    "collection_name": "mem0",
    "embedding_model_dims": 1536,
    "faiss_path": "/data/faiss_index",
    "faiss_distance_strategy": "euclidean"
  },
  "llm": {
    "provider": "lmstudio",
    "model": "local-model-name",
    "temperature": 0.2,
    "max_tokens": 2000,
    "lmstudio_base_url": "http://localhost:1234/v1"
  },
  "embedder": {
    "provider": "openai",
    "model": "text-embedding-3-small",
    "dimension": 1536
  }
}
