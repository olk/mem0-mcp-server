{
  "config_id": "s3-vectors-ollama",
  "memory_expiry": 3600,
  "logging_level": "INFO",
  "host": "0.0.0.0",
  "port": 8080,
  "transport": "sse",
  "vector_store": {
    "provider": "s3_vectors",
    "collection_name": "mem0",
    "embedding_model_dims": 1536,
    "s3_vectors_bucket": "your-vector-bucket-name",
    "s3_vectors_region": "us-east-1"
  },
  "llm": {
    "provider": "ollama",
    "model": "llama3.2",
    "temperature": 0.2,
    "max_tokens": 2000,
    "ollama_base_url": "http://localhost:11434"
  },
  "embedder": {
    "provider": "ollama",
    "model": "nomic-embed-text",
    "dimension": 1536,
    "ollama_base_url": "http://localhost:11434"
  }
}
